{
  "name": "election-contracts",
  "version": "1.0.0",
  "description": "Hardhat contracts for the E-Voting System",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "coverage": "hardhat coverage",
    "node": "hardhat node",
    "deploy:local": "hardhat run scripts/deploy.js --network localhost",
    "deploy:amoy": "hardhat run scripts/deploy.js --network amoy",
    "setup": "hardhat compile && hardhat run scripts/deploy.js --network localhost",
    "grant-roles": "hardhat run scripts/grant-roles.js --network localhost",
    "fund-accounts": "hardhat run scripts/fund-accounts.js --network localhost"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat": "^2.19.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "dotenv": "^17.4.2"
  }
}
